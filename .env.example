FLASK_ENV=production
FLASK_DEBUG=false
PORT=8000

# Active l'enregistrement en base seulement si RDS est configure
ENABLE_DB_RECORDING=true
DATABASE_URL=mysql+pymysql://username:password@your-rds-endpoint:3306/predict
AUTO_CREATE_DB=false
DB_POOL_RECYCLE=280

# Choisir soit un modele local, soit un modele stocke sur S3
MODEL_PATH=model_pipeline_complet4.pkl
# MODEL_S3_URI=s3://your-bucket/models/model_pipeline_complet4.pkl
MODEL_CACHE_DIR=/tmp/projet_cloud_api_models

# Domaines front autorises a appeler l'API
FRONTEND_ORIGINS=https://your-frontend.s3-website-region.amazonaws.com,https://www.your-domain.com
